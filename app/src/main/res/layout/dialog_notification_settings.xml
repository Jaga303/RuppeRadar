<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notifications Preferences"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Budget Limit Alerts"
            android:textSize="16sp"
            android:textColor="@color/black"/>

        <Switch
            android:id="@+id/swLimitExceeds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Daily Reminder"
            android:textSize="16sp"
            android:textColor="@color/black"/>

        <Switch
            android:id="@+id/swDailyAlert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtAlertTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reminder Time: 20:00"
        android:textSize="14sp"
        android:textColor="#1976D2"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        android:layout_marginStart="0dp"/>

</LinearLayout>
